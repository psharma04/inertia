{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "copy-assets": "node scripts/copy-assets.mjs",
    "prebuild": "node scripts/copy-assets.mjs",
    "predev": "node scripts/copy-assets.mjs",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "cf:build": "bunx opennextjs-cloudflare build",
    "cf:preview": "bunx opennextjs-cloudflare build && wrangler dev",
    "deploy": "bunx opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@workspace/ui": "workspace:*",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.79.0"
  }
}
